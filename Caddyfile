# --- PROJET RECEPTIONIST (vitrine vocale Vapi) — app Docker nginx sur :3005 ---

# Compression + cache des assets statiques Vite
(spa_optim) {
    encode gzip zstd
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
}

# CSP — Supabase (REST + Realtime + Edge Functions), Vapi (WebRTC voix), Cal.com
(csp_receptionist) {
    header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://unpkg.com https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://uvpuhoyaovmztephqknq.supabase.co wss://uvpuhoyaovmztephqknq.supabase.co https://*.vapi.ai wss://*.vapi.ai https://*.daily.co wss://*.daily.co https://*.pluot.blue https://api.cal.com https://*.cal.com https://places.googleapis.com; media-src 'self' blob: data: mediastream: https://uvpuhoyaovmztephqknq.supabase.co; frame-src 'self' https://cal.com https://*.cal.com https://*.daily.co; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
}

receptionist.zerocall.io {
    # Sécurité de base — inline (pas import base_security) car la Permissions-Policy
    # doit autoriser microphone=(self) pour l'assistant vocal Vapi.
    header {
        -Server
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Permissions-Policy "camera=(), geolocation=(), payment=(), usb=(), bluetooth=(), microphone=(self)"
    }
    import csp_receptionist
    import spa_optim

    reverse_proxy 127.0.0.1:3005 {
        import proxy_config
    }

    log {
        output file /var/log/caddy/receptionist.zerocall.io.log {
            roll_size 10MB
            roll_keep 3
        }
    }
}
